# Shared database. Required for production web and worker; use a Railway
# Postgres variable reference in Railway, not copied plaintext credentials.
DATABASE_URL=
DATABASE_URL_TEST=

# Web runtime. Required for production web only.
BETTER_AUTH_SECRET=
# Local development can use localhost. Production must be the public HTTPS web
# origin, for example https://web-production-26609.up.railway.app, never
# localhost, loopback, or *.railway.internal.
BETTER_AUTH_URL=http://localhost:3000
# Required only by the production /setup flow while first-owner setup is available.
# Enter it in the /setup form; never put it in URLs.
OWNER_SETUP_TOKEN=

# Historical/inactive MonoPay / Monobank support. Leave blank for the active
# manual online-card transfer flow and normal production startup; set only for
# deliberate historical retry or webhook verification.
MONOBANK_TOKEN=
MONOBANK_API_URL=
MONOBANK_PUBLIC_KEY=
MONOBANK_WEBHOOK_SECRET_OR_PUBLIC_KEY=

# Shipping mode. mock is for local/e2e only; production defaults to disabled
# unless explicitly set to live.
SHIPPING_LABEL_CREATION_MODE=mock

NOVA_POST_API_KEY=
NOVA_POST_API_URL=https://api.novapost.com/v.1.0/
# Optional when authorization cannot be derived from NOVA_POST_API_URL.
NOVA_POST_AUTH_URL=
NOVA_POST_SENDER_COUNTRY_CODE=UA
NOVA_POST_SENDER_DIVISION_ID=
NOVA_POST_SENDER_NAME=
NOVA_POST_SENDER_PHONE=
NOVA_POST_SENDER_EMAIL=
NOVA_POST_SENDER_COMPANY_TIN=
NOVA_POST_SENDER_COMPANY_NAME=
NOVA_POST_PAYER_TYPE=Recipient
NOVA_POST_PAYER_CONTRACT_NUMBER=
NOVA_POST_DEFAULT_WIDTH_MM=200
NOVA_POST_DEFAULT_LENGTH_MM=300
NOVA_POST_DEFAULT_HEIGHT_MM=100
NOVA_POST_DEFAULT_ACTUAL_WEIGHT_GRAMS=500
NOVA_POST_DEFAULT_VOLUMETRIC_WEIGHT_GRAMS=500
# Deprecated compatibility names. Prefer NOVA_POST_* for all new deployments.
NOVA_POSHTA_API_KEY=
NOVA_POSHTA_API_URL=

# Worker runtime. Required for production worker.
AUTO_COMPLETE_AFTER_DELIVERED_HOURS=24

# Runtime/tooling-managed variables; usually set by Next.js, Railway, or CI.
# NODE_ENV=development
# CI=

# Test-only seeded auth/catalog fallback for Playwright. Never set in production.
PLAYWRIGHT_E2E=
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100

# Test/development-only carrier directory fixtures. Never set in production.
USE_MOCK_SHIPPING_CARRIERS=
